{
  "name": "@ai-native-solutions/fallbuild-sdk",
  "version": "1.0.0",
  "description": "Sovereign single-file low-code app builder — programmatic core. 8 widgets, 5 templates, standalone HTML export.",
  "license": "MIT",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": ["src", "README.md", "LICENSE"],
  "keywords": ["low-code", "app-builder", "sovereign", "single-file", "html-export", "ai-native-solutions"],
  "author": "AI-Native Solutions <hello@ai-nativesolutions.com>",
  "homepage": "https://sjgant80-hub.github.io/fallbuild-sdk/",
  "repository": { "type": "git", "url": "https://github.com/sjgant80-hub/fallbuild-sdk.git" },
  "bugs": { "url": "https://github.com/sjgant80-hub/fallbuild-sdk/issues" },
  "engines": { "node": ">=18" },
  "scripts": {
    "smoke": "node -e \"import('./src/index.js').then(m=>{const a=m.applyTemplate('CRUD app');const html=m.renderStandaloneHtml(a);console.log('template:',a.name,'pages:',a.pages.length,'widgets:',a.pages.reduce((n,p)=>n+p.widgets.length,0),'html:',html.length,'bytes')})\""
  },
  "publishConfig": { "access": "public" }
}
